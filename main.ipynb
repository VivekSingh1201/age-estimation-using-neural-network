   "source": [
    "from tensorflow import keras\n",
    "from tensorflow.keras.models import Sequential\n",
    "from tensorflow.keras.layers import Input, Flatten, Dense\n",
    "\n",
    "def bias_initializer_experiment(bias_initializers, bias_names):\n",
    "\n",
    "    histories = {}\n",
    "\n",
    "    for bias_init, bias_name in zip(bias_initializers, bias_names):\n",
    "\n",
    "        # Fresh model for each experiment\n",
    "        model = Sequential([\n",
    "            Input(shape=input_num_units),\n",
    "            Flatten(),\n",
    "            Dense(units=hidden_num_units,activation='relu',bias_initializer=bias_init),\n",
    "            Dense(units=output_num_units,activation='softmax')\n",
    "        ])\n",
    "\n",
    "        # Compile model\n",
    "        model.compile(loss='categorical_crossentropy',optimizer=keras.optimizers.Adam(),metrics=['accuracy'])\n",
    "\n",
    "        # TensorBoard log directory\n",
    "        logdir = f'biases/{bias_name}'\n",
    "\n",
    "        tensorboard_cb = keras.callbacks.TensorBoard(log_dir=logdir,write_graph=False\n",
    "        )\n",
    "\n",
    "        print(f'Training model with bias initializer: {bias_name}')\n",
    "\n",
    "        history = model.fit(train_x,train_y,batch_size=32,epochs=epochs,validation_split=0.2,callbacks=[tensorboard_cb],verbose=1)\n",
    "\n",
    "        histories[bias_name] = history\n",
    "\n",
