   "source": [
    "from tensorflow import keras\n",
    "from tensorflow.keras.models import Sequential\n",
    "from tensorflow.keras.layers import Input, Flatten, Dense\n",
    "\n",
    "epochs = 21\n",
    "batch_size = 32\n",
    "\n",
    "def regularization_experiment(regularizers, regularizer_names):\n",
    "\n",
    "    histories = {}\n",
    "\n",
    "    for reg, reg_name in zip(regularizers, regularizer_names):\n",
    "\n",
    "        # Fresh model for each experiment\n",
    "        model = Sequential([\n",
    "            Input(shape=input_num_units),\n",
    "\n",
    "            Flatten(),\n",
    "\n",
    "            Dense(\n",
    "                units=hidden_num_units,\n",
    "                activation='relu',\n",
    "                kernel_regularizer=reg\n",
    "            ),\n",
    "\n",
    "            Dense(\n",
    "                units=output_num_units,\n",
    "                activation='softmax'\n",
    "            )\n",
    "        ])\n",
    "\n",
    "        # Compile model\n",
    "        model.compile(\n",
    "            loss='categorical_crossentropy',\n",
    "            optimizer=keras.optimizers.Adam(),\n",
    "            metrics=['accuracy']\n",
    "        )\n",
    "\n",
    "        # TensorBoard log directory\n",
    "        logdir = f'regularization/{reg_name}'\n",
    "\n",
    "        tensorboard_cb = keras.callbacks.TensorBoard(\n",
    "            log_dir=logdir,\n",
    "            write_graph=False\n",
    "        )\n",
    "\n",
    "        print(f'Training model using {reg_name} regularization')\n",
    "\n",
    "        history = model.fit(\n",
    "            train_x,\n",
    "            train_y,\n",
    "            batch_size=batch_size,\n",
    "            epochs=epochs,\n",
    "            validation_split=0.2,\n",
    "            callbacks=[tensorboard_cb],\n",
    "            verbose=1\n",
