   "source": [
    "# Function to create a fresh model\n",
    "from tensorflow.keras.models import Sequential\n",
    "from tensorflow.keras.layers import Input, Flatten, Dense\n",
    "\n",
    "\n",
    "def create_model():\n",
    "\n",
    "    model = Sequential([\n",
    "\n",
    "        Input(shape=(32, 32, 3)),\n",
    "\n",
    "        Flatten(),\n",
    "\n",
    "        Dense(500, activation='relu'),\n",
    "\n",
    "        Dense(3, activation='softmax')\n",
    "\n",
    "    ])\n",
    "\n",
    "    return model\n",
    "\n",
    "\n",
    "def models_with_different_optimizers(list_of_optimizers):\n",
    "\n",
    "    for optimizer in list_of_optimizers:\n",
    "\n",
    "        # Create fresh model each time\n",
    "        model = create_model()\n",
    "\n",
    "        # Compile model\n",
    "        model.compile(\n",
    "            loss='categorical_crossentropy',\n",
    "            optimizer=optimizer,\n",
    "            metrics=['accuracy']\n",
    "        )\n",
    "\n",
    "        # Optimizer name\n",
    "        val = optimizer.__class__.__name__\n",
    "\n",
    "        # Separate TensorBoard folder\n",
    "        logdir = f'optims/{val}'\n",
    "\n",
    "        # TensorBoard callback\n",
    "        cb = keras.callbacks.TensorBoard(\n",
    "            log_dir=logdir,\n",
    "            write_graph=False\n",
    "        )\n",
    "\n",
    "        print(f'Building model using {val} optimizer')\n",
    "\n",
    "        # Train model\n",
    "        history = model.fit(\n",
    "            train_x,\n",
    "            train_y,\n",
    "            epochs=epochs,\n",
    "            batch_size=32,\n",
    "            validation_split=0.2,\n",
    "            callbacks=[cb],\n",
    "            verbose=1\n",
    "        )\n",
    "\n",
    "        print(f'{val} model built successfully.\\n')\n",
    "\n",
    "\n",
    "# Optimizer list\n",
    "optims = [\n",
    "    keras.optimizers.Adam(),\n",
    "    keras.optimizers.Adadelta(),\n",
    "    keras.optimizers.Adagrad(),\n",
    "    keras.optimizers.RMSprop(),\n",
    "    keras.optimizers.SGD()\n",
    "]\n",
    "\n",
    "# Run comparison\n",
    " models_with_different_optimizers(optims)"
   ]
  },
