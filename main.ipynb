    "from tensorflow.keras.models import Sequential\n",
    "from tensorflow.keras.layers import Input, Flatten, Dense\n",
    "from tensorflow import keras\n",
    "\n",
    "def models_with_different_activation_fn(list_of_activation_fn):\n",
    "\n",
    "    for activation in list_of_activation_fn:\n",
    "\n",
    "        model = Sequential([\n",
    "            Input(shape=input_num_units),\n",
    "            Flatten(),\n",
    "            Dense(units=hidden_num_units, activation=activation),\n",
    "            Dense(units=output_num_units, activation='softmax'),\n",
    "        ])\n",
    "\n",
    "        model.compile(\n",
    "            loss='categorical_crossentropy',\n",
    "            optimizer=keras.optimizers.Adam(),\n",
    "            metrics=['accuracy']\n",
    "        )\n",
    "\n",
    "        logdir = f'activation/{activation}'\n",
    "\n",
    "        cb = keras.callbacks.TensorBoard(\n",
    "            log_dir=logdir,\n",
    "            write_graph=False\n",
    "        )\n",
    "\n",
    "        print(f'Building model using {activation} activation function')\n",
    "\n",
    "        history = model.fit(\n",
    "            train_x,\n",
    "            train_y,\n",
    "            epochs=epochs,\n",
    "            batch_size=32,\n",
    "            validation_split=0.2,\n",
    "            callbacks=[cb],\n",
    "            verbose=1\n",
    "        )\n",
    "\n",
    "        print('Model built successfully.\\n')\n",
    "\n",
    "\n",
    "# Better activation list\n",
    "act = ['linear', 'sigmoid', 'tanh', 'relu']\n",
    "\n",
    " models_with_different_activation_fn(act)"
   ]
